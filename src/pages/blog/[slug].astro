---
import CustomLink from "@components/CustomLink.astro";
import FormattedDate from "@components/FormattedDate.astro";
import MainLayout from "@layouts/MainLayout.astro";
import Contact from "@sections/Contact.astro";
import articles from "@data/articles.json";

export async function getStaticPaths() {
  return articles.articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;

// Simple markdown parser for headings, paragraphs, and lists
function parseMarkdown(content: string): string {
  const lines = content.split("\n");
  const blocks: string[] = [];
  let currentBlock: string[] = [];
  let inList = false;

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i].trim();
    const isEmpty = line === "";

    // Handle headings
    if (line.startsWith("## ")) {
      if (currentBlock.length > 0) {
        blocks.push(currentBlock.join("\n"));
        currentBlock = [];
      }
      blocks.push(`<h2>${line.replace(/^## /, "")}</h2>`);
      inList = false;
      continue;
    }
    if (line.startsWith("### ")) {
      if (currentBlock.length > 0) {
        blocks.push(currentBlock.join("\n"));
        currentBlock = [];
      }
      blocks.push(`<h3>${line.replace(/^### /, "")}</h3>`);
      inList = false;
      continue;
    }

    // Handle list items
    if (line.startsWith("- ")) {
      if (!inList && currentBlock.length > 0) {
        blocks.push(`<p>${currentBlock.join(" ")}</p>`);
        currentBlock = [];
      }
      inList = true;
      currentBlock.push(line.replace(/^- /, ""));
      continue;
    }

    // Empty line - end current block
    if (isEmpty) {
      if (currentBlock.length > 0) {
        if (inList) {
          blocks.push(
            `<ul>${currentBlock.map((item) => `<li>${item}</li>`).join("")}</ul>`,
          );
          inList = false;
        } else {
          blocks.push(`<p>${currentBlock.join(" ")}</p>`);
        }
        currentBlock = [];
      }
      continue;
    }

    // Regular text
    if (inList) {
      // End list and start paragraph
      blocks.push(
        `<ul>${currentBlock.map((item) => `<li>${item}</li>`).join("")}</ul>`,
      );
      currentBlock = [line];
      inList = false;
    } else {
      currentBlock.push(line);
    }
  }

  // Handle remaining content
  if (currentBlock.length > 0) {
    if (inList) {
      blocks.push(
        `<ul>${currentBlock.map((item) => `<li>${item}</li>`).join("")}</ul>`,
      );
    } else {
      blocks.push(`<p>${currentBlock.join(" ")}</p>`);
    }
  }

  return blocks.join("");
}
---

<style>
  .heroSection {
    padding: 0;
  }

  .articleMeta {
    display: flex;
    align-items: center;
    gap: var(--element-gap);
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: var(--element-gap-large);
  }

  .articleContent {
    padding: 0;
  }

  .articleContent h2 {
    margin-top: var(--element-gap-large);
    margin-bottom: var(--element-gap);
    color: var(--color-text-primary);
    font-size: clamp(1.5rem, 3vw, 1.75rem);
  }

  .articleContent h3 {
    margin-top: var(--element-gap);
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
  }

  .articleContent p {
    color: var(--color-text-primary);
    line-height: 1.5;
    margin-bottom: var(--element-gap);
  }

  .articleContent ul,
  .articleContent ol {
    color: var(--color-text-primary);
    line-height: 1.5;
  }

  .backLink {
    margin-bottom: var(--element-gap-large);
    display: inline-block;
  }

  .articleHeader h1 {
    margin-bottom: var(--element-gap);
  }
</style>

<MainLayout title={article.title} description={article.description}>
  <section class="heroSection">
    <div class="backLink">
      <CustomLink href="/blog" text="← Back to Blog" variant="outline" />
    </div>
    <div class="articleHeader">
      <div class="articleMeta">
        <FormattedDate date={new Date(article.date)} />
      </div>
      <h1>{article.title}</h1>
    </div>
  </section>

  <section class="articleContent">
    <div set:html={parseMarkdown(article.content)} />
  </section>

  <Contact />
</MainLayout>
