---

<style>
  .heroSection {
    padding: 0;
  }

  .hero {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
  }

  .hero p {
    color: var(--color-text-muted);
  }

  .blogSection {
    padding: 0;
  }

  .articlesGrid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--element-gap-large);
  }

  .articleCard {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--element-gap-large);
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
    background: transparent;
    transition: transform var(--transition-base);
  }

  .articleCard:hover {
    transform: translateY(var(--translate-lift-sm));
  }

  .articleHeader {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
  }

  .articleMeta {
    display: flex;
    align-items: center;
    gap: var(--element-gap);
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .articleCard h3 {
    margin: 0;
    color: var(--color-text);
    font-size: 1.5rem;
  }

  .articleDescription {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .articleFooter {
    margin-top: auto;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: var(--element-gap);
  }

  @media screen and (width >= 768px) {
    .hero {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }

    .articlesGrid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<MainLayout
  title="Blog"
  description="Articles, tutorials, and insights on web development and technology."
>
  <section class="heroSection">
    <div class="hero">
      <div>
        <h1>Blog</h1>
        <p>
          Articles, tutorials, and insights on web development, technology, and
          best practices. Explore my thoughts and experiences in the field.
        </p>
      </div>
    </div>
  </section>

