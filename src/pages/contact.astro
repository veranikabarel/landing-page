---
import MainLayout from "@layouts/MainLayout.astro";
import CustomButton from "@components/CustomButton.astro";

const email = "veranikabarel@gmail.com";
---

<style>
  .contactSection {
    padding-inline: 12px;
  }

  .contactSection h1 {
    margin-bottom: 2rem;
  }

  .formWrapper {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .emailDisplay {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .emailDisplay p {
    margin: 0;
    font-size: 1.05rem;
    color: var(--color-text);
    font-weight: 500;
  }

  .copyButton {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    transition: all var(--transition-base);
  }

  .copyButton:hover {
    background: var(--color-surface-muted);
    color: var(--color-accent-strong);
  }

  .copyButton:active {
    transform: scale(0.95);
  }

  .copyButton.copied {
    color: var(--color-highlight);
  }

  .copyButton svg {
    width: 20px;
    height: 20px;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .formGroup {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .formGroup label {
    font-weight: 500;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .formGroup input,
  .formGroup textarea {
    padding: 0.85rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-surface);
    transition: all var(--transition-base);
    width: 100%;
  }

  .formGroup input:focus,
  .formGroup textarea:focus {
    outline: none;
    border-color: var(--color-accent-strong);
    box-shadow: 0 0 0 3px var(--color-accent-soft);
  }

  .formGroup input:invalid:not(:placeholder-shown),
  .formGroup textarea:invalid:not(:placeholder-shown) {
    border-color: #ef4444;
  }

  .formGroup textarea {
    resize: vertical;
    min-height: 120px;
    font-family: inherit;
  }

  .errorMessage {
    color: #ef4444;
    font-size: 0.875rem;
    margin-top: 0.25rem;
    display: none;
  }

  .formGroup input:invalid:not(:placeholder-shown) ~ .errorMessage,
  .formGroup textarea:invalid:not(:placeholder-shown) ~ .errorMessage {
    display: block;
  }

  .submitButton {
    margin-top: 0.5rem;
    align-self: flex-start;
  }

  @media screen and (width >= 768px) {
    .contactSection {
      padding-inline: 32px;
    }

    .form {
      width: 100%;
    }
  }

  @media screen and (width >= 1200px) {
    .contactSection {
      padding-inline: 48px;
      height: 100vh;
    }

    .formWrapper {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }

    .emailDisplay {
      width: 45%;
      flex-shrink: 0;
    }

    .form {
      width: 50%;
    }
  }
</style>

<MainLayout
  title="Contact me page"
  description="Get in touch with Veranika Kasparevych"
>
  <section class="contactSection">
    <h1>Contact me!</h1>
    <div class="formWrapper">
      <div class="emailDisplay">
        <p id="emailText">{email}</p>
        <button
          class="copyButton"
          id="copyButton"
          type="button"
          aria-label="Copy email address"
          title="Copy email address"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
            ></path>
          </svg>
        </button>
      </div>

      <form class="form" id="contactForm" novalidate>
        <div class="formGroup">
          <label for="name">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            minlength="2"
            maxlength="50"
            placeholder="Your name"
            pattern="[A-Za-z\s]+"
            title="Name should contain only letters and spaces"
          />
          <span class="errorMessage"
            >Please enter a valid name (2-50 characters, letters only)</span
          >
        </div>

        <div class="formGroup">
          <label for="email">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="your.email@example.com"
            pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$"
            title="Please enter a valid email address"
          />
          <span class="errorMessage">Please enter a valid email address</span>
        </div>

        <div class="formGroup">
          <label for="message">Message</label>
          <textarea
            id="message"
            name="message"
            required
            minlength="10"
            maxlength="1000"
            placeholder="Your message..."
            rows="6"></textarea>
          <span class="errorMessage"
            >Message must be between 10 and 1000 characters</span
          >
        </div>

        <CustomButton type="submit" text="Send Message" class="submitButton" />
      </form>
    </div>
  </section>
</MainLayout>

<script>
  // Copy email functionality
  const copyButton = document.getElementById("copyButton");
  const emailText = document.getElementById("emailText");
  const email = emailText?.textContent?.trim() || "";

  if (copyButton && email) {
    copyButton.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(email);
        copyButton.classList.add("copied");
        copyButton.setAttribute("aria-label", "Email copied!");
        copyButton.setAttribute("title", "Email copied!");

        // Update icon to checkmark temporarily
        const svg = copyButton.querySelector("svg");
        if (svg) {
          const originalSvg = svg.outerHTML;
          svg.outerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          `;

          setTimeout(() => {
            copyButton.classList.remove("copied");
            copyButton.setAttribute("aria-label", "Copy email address");
            copyButton.setAttribute("title", "Copy email address");
            copyButton.innerHTML = originalSvg;
          }, 2000);
        }
      } catch (err) {
        console.error("Failed to copy email:", err);
        // Fallback for older browsers
        const textArea = document.createElement("textarea");
        textArea.value = email;
        textArea.style.position = "fixed";
        textArea.style.opacity = "0";
        document.body.appendChild(textArea);
        textArea.select();
        try {
          document.execCommand("copy");
          copyButton.classList.add("copied");
          setTimeout(() => {
            copyButton.classList.remove("copied");
          }, 2000);
        } catch (fallbackErr) {
          console.error("Fallback copy failed:", fallbackErr);
        }
        document.body.removeChild(textArea);
      }
    });
  }

  // Form validation and submission
  const contactForm = document.getElementById("contactForm") as HTMLFormElement;
  if (contactForm) {
    contactForm.addEventListener("submit", (e) => {
      e.preventDefault();

      const nameInput = contactForm.querySelector("#name") as HTMLInputElement;
      const emailInput = contactForm.querySelector(
        "#email",
      ) as HTMLInputElement;
      const messageInput = contactForm.querySelector(
        "#message",
      ) as HTMLTextAreaElement;

      let isValid = true;

      // Validate name
      if (!nameInput.value.trim() || nameInput.value.trim().length < 2) {
        nameInput.setCustomValidity("Name must be at least 2 characters");
        isValid = false;
      } else if (!/^[A-Za-z\s]+$/.test(nameInput.value.trim())) {
        nameInput.setCustomValidity(
          "Name should contain only letters and spaces",
        );
        isValid = false;
      } else {
        nameInput.setCustomValidity("");
      }

      // Validate email
      const emailRegex = /^[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$/i;
      if (
        !emailInput.value.trim() ||
        !emailRegex.test(emailInput.value.trim())
      ) {
        emailInput.setCustomValidity("Please enter a valid email address");
        isValid = false;
      } else {
        emailInput.setCustomValidity("");
      }

      // Validate message
      if (!messageInput.value.trim() || messageInput.value.trim().length < 10) {
        messageInput.setCustomValidity(
          "Message must be at least 10 characters",
        );
        isValid = false;
      } else if (messageInput.value.trim().length > 1000) {
        messageInput.setCustomValidity(
          "Message must be less than 1000 characters",
        );
        isValid = false;
      } else {
        messageInput.setCustomValidity("");
      }

      if (isValid) {
        // Here you would typically send the form data to a server
        // For now, we'll just show an alert
        alert("Thank you for your message! I'll get back to you soon.");
        contactForm.reset();
      } else {
        // Trigger validation display
        contactForm.reportValidity();
      }
    });

    // Real-time validation feedback
    const inputs = contactForm.querySelectorAll("input, textarea");
    inputs.forEach((input) => {
      input.addEventListener("blur", () => {
        (input as HTMLInputElement | HTMLTextAreaElement).checkValidity();
      });

      input.addEventListener("input", () => {
        const inputElement = input as HTMLInputElement | HTMLTextAreaElement;
        if (inputElement.validity.valid) {
          inputElement.setCustomValidity("");
        }
      });
    });
  }
</script>
