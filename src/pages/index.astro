---
import CustomButton from "@components/CustomButton.astro";
import CustomLink from "@components/CustomLink.astro";
import MainLayout from "@layouts/MainLayout.astro";
import Contact from "@sections/Contact.astro";
import profilePicture from "../styles/img.jpg";
import workspacePhoto from "../styles/computer.jpg";

const heroStats = [
  { value: "3+", label: "Years shipping UI" },
  { value: "React + Next.js", label: "Preferred stack" },
];
---

<style>
  .hero-section {
    background:
      linear-gradient(
        145deg,
        rgba(124, 77, 255, 0.07),
        rgba(16, 185, 129, 0.05)
      ),
      #fff;
  }

  .hero-grid {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .hero-copy h1 {
    margin-top: 0.5rem;
  }

  .hero-lede {
    margin-top: 1rem;
    font-size: 1.1rem;
  }

  .hero-contact {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hero-contact a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text);
    font-weight: 600;
  }

  .hero-stats {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
  }

  .stat-card {
    padding: 1.5rem;
    border-radius: var(--radius-md);
    background: var(--color-surface-muted);
    border: 1px solid rgba(15, 23, 42, 0.08);
  }

  .stat-value {
    display: block;
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.1;
  }

  .stat-label {
    color: var(--color-text-muted);
  }

  .hero-media {
    position: relative;
    display: grid;
    gap: 1.5rem;
  }

  .hero-media figure {
    margin: 0;
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
  }

  .hero-media img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .hero-note {
    padding: 1rem 1.25rem;
    border-radius: var(--radius-md);
    background: #fff;
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: var(--shadow-cut);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .about-section {
    background: #fff;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .story-grid {
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
  }

  .story-grid img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
  }

  .tech-section {
    /* background: linear-gradient(120deg, rgba(124, 77, 255, 0.08), rgba(16, 185, 129, 0.08));
     */
    background: #fff;
  }

  .tech-section .section-header {
    margin-bottom: 1.5rem;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
  }

  .tech-grid .icon-tile {
    min-height: 110px;
  }

  .tech-grid svg {
    width: clamp(40px, 8vw, 64px);
    height: clamp(40px, 8vw, 64px);
  }

  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1fr) minmax(320px, 420px);
    }

    .story-grid {
      grid-template-columns: minmax(280px, 1fr) minmax(0, 1.2fr);
      align-items: center;
    }
  }
</style>

<MainLayout title="Main page" description="Lorem ipsum dolor sit amet">
  <section class="hero-section surface-muted">
    <div class="hero-grid">
      <div class="hero-copy animate-fade-up">
        <p class="eyebrow">Front-end developer</p>
        <h1>Veranika Kasparevych</h1>
        <p class="hero-lede">
          I design and code delightful, accessible web experiences. From
          prototypes to production-ready interfaces, I bridge design and
          engineering so teams can move faster with confidence.
        </p>

        <div class="hero-contact">
          <a href="mailto:veranikabarel@gmail.com">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
            >
              <path
                fill="currentColor"
                d="M19 4H5c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2m0 4l-7 4l-7-4V6l7 4l7-4z"
              ></path>
            </svg>
            veranikabarel@gmail.com
          </a>
        </div>

        <ul class="hero-stats">
          {
            heroStats.map((stat) => (
              <li class="stat-card">
                <span class="stat-value">{stat.value}</span>
                <span class="stat-label">{stat.label}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="hero-media animate-float">
        <figure>
          <img
            src={profilePicture.src}
            alt="Portrait of Veranika Kasperevych smiling"
            loading="lazy"
            decoding="async"
          />
        </figure>
        <div class="hero-note">
          <strong>Currently in Wrocław, Poland</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="about-section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Design-first engineering mindset</p>
      </div>
      <CustomLink href="/about" text="More about me" variant="outline" />
    </div>
    <div class="story-grid">
      <img
        src={workspacePhoto.src}
        alt="Minimalist workspace with a laptop and headphones"
        loading="lazy"
        decoding="async"
      />
      <div>
        <p>
          Creative front-end developer with a passion for building intuitive,
          user-centric web applications. I specialize in crafting seamless
          digital experiences using modern technologies like React, Next.js, and
          Astro—pairing solid engineering practices with refined visual polish.
        </p>
        <p>
          Outside of work, I’m usually experimenting with side projects, sharing
          knowledge with the dev community, or sketching new interface ideas.
          Collaboration lights me up, and I love translating bold concepts into
          reliable, performant UI.
        </p>
      </div>
    </div>
  </section>

  <section class="tech-section surface-muted">
    <div class="section-header">
      <div>
        <p class="eyebrow">Toolbox</p>
      </div>
