---
import BaseLayout from '../layouts/BaseLayout.astro';
import activitiesData from '../data/activities.json';
import experienceData from '../data/experience.json';
import referralsData from '../data/referrals.json';
import skillsData from '../data/skills.json';
import languagesData from '../data/languages.json';

const { presentations } = activitiesData;
const { experience } = experienceData;
const { referrals } = referralsData;
const { skills_and_tools } = skillsData;
const { languages } = languagesData;

const cardClasses = ['wc-1', 'wc-2', 'wc-3', 'wc-4'];
const skillGroupTitles: Record<string, string> = {
  languages_and_frameworks: 'Languages & Frameworks',
  styling: 'Styling Systems',
  testing: 'Testing',
  tools: 'Tooling',
  visualization_and_cms: 'Visualization & CMS',
  network_and_data: 'Network & Data',
  build_tools: 'Build Tools',
};
---

<BaseLayout title="Veranika Kasparevych – Front-end Engineer">
  <!-- — HERO — -->
  <section class="hero">
    <div class="hero-left">
      <h1 class="hero-name">
        VERANIKA<br />
        <span>KASPAREVYCH</span>
      </h1>
    </div>
    <div class="hero-right">
      <div class="hero-available">Currently available for partnerships</div>
      <p class="hero-bio">
        Front-end engineer with <strong>4+ years</strong> building interactive, user-centric
        applications. I pair <strong>solid engineering</strong> with refined visual
        polish — crafting seamless digital experiences using React, Next.js, and Astro.
      </p>
      <div class="hero-stats">
        <div>
          <div class="stat-num">4+</div>
          <div class="stat-label">Years shipping UI</div>
        </div>
        <div>
          <div class="stat-num">React + Next.js</div>
          <div class="stat-label">Preferred stack</div>
        </div>
      </div>
      <a href="mailto:vkasparevych@gmail.com" class="hero-cta">
        Get in touch
        <span class="hero-cta-arrow">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path
              d="M2 7H12M12 7L7 2M12 7L7 12"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </a>
      <a href="#work" class="hero-scroll-label">
        <span>Scroll to explore</span>
        <div class="hero-scroll-arrow"></div>
      </a>
    </div>
  </section>

  <!-- — WORK — -->
  <section class="section" id="work">
    <div class="section-header fade-up">
      <div>
        <div class="section-num">01 / Work</div>
        <h2 class="section-label">SELECTED<br />PROJECTS</h2>
      </div>
    </div>
    <div class="work-grid">
      {
        presentations.map((item, i) => (
          <div
            class={`work-card ${cardClasses[i % cardClasses.length]} fade-up`}
          >
            <div class="work-card-inner">
              <div class="work-card-bg-text">{item.label}</div>
              <div class="work-tag">{item.tag}</div>
              <div class="work-title">{item.title}</div>
              <div class="work-desc">{item.description}</div>
              {item.link && (
                <a href={item.link} class="work-link" target="_blank" rel="noopener noreferrer">
                  View →
                </a>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- — SKILLS — -->
  <section class="skills-section" id="skills">
    <div class="skills-left fade-up">
      <div
        class="section-num"
        style="color:rgba(255,255,255,0.3);margin-bottom:12px;"
      >
        02 / Skills
      </div>
      <h2 class="section-label">TECH<br />STACK</h2>
      <p class="skills-intro">
        A full toolkit for building modern, performant, and maintainable web
        applications — from architecture to pixel-perfect polish.
      </p>
    </div>
    <div class="skills-grid fade-up">
      {
        Object.entries(skills_and_tools).map(([key, items]) => (
          <div class="skill-group">
            <div class="skill-group-title">{skillGroupTitles[key] ?? key}</div>
            {items.map((s) => (
              <span class="skill-tag">{s}</span>
            ))}
          </div>
        ))
      }
      <div class="skill-group">
        <div class="skill-group-title">Languages spoken</div>
        {
          languages.map((l) => (
            <span class="skill-tag">
              {l.language} ({l.proficiency})
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- — EXPERIENCE — -->
  <section class="exp-section" id="experience">
    <div class="section-header fade-up">
      <div>
        <div class="section-num">03 / Experience</div>
        <h2 class="section-label">WHERE I'VE<br />WORKED</h2>
      </div>
    </div>
    <div class="exp-list">
      {
        experience.map((job, i) => (
          <div class="exp-item fade-up">
            <div class="exp-period">{job.date}</div>
            <div>
              <div class="exp-role">{job.job_title}</div>
              <div class="exp-company">{job.company}</div>
              <ul class="exp-bullets">
                {job.responsibilities.map((r) => (
                  <li>{r}</li>
                ))}
              </ul>
            </div>
            <div class="exp-num">0{i + 1}</div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- — TESTIMONIALS — -->
  <section class="testimonials" id="testimonials">
    <div class="section-header fade-up">
      <div>
        <div
          class="section-num"
          style="color:rgba(255,255,255,0.4);margin-bottom:12px;"
        >
          04 / Referrals
        </div>
        <h2 class="section-label">WHAT<br />THEY SAY</h2>
      </div>
    </div>
    <div class="carousel" id="carousel">
      <div class="carousel-track" id="carouselTrack">
        {
          referrals.map((r) => (
            <div class="testimonial-card carousel-slide">
              <p class="t-quote">"{r.quote}"</p>
              <div class="t-author">{r.name}</div>
              <div class="t-role">{r.role}</div>
            </div>
          ))
        }
      </div>
      <div class="carousel-controls">
        <button class="carousel-btn" id="prevBtn" aria-label="Previous">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path
              d="M10 12L6 8L10 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
        <div class="carousel-dots" id="carouselDots">
          {
            referrals.map((_, i) => (
              <button
                class="dot"
                data-index={String(i)}
                aria-label={`Go to slide ${i + 1}`}
              />
            ))
          }
        </div>
        <button class="carousel-btn" id="nextBtn" aria-label="Next">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path
              d="M6 4L10 8L6 12"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <script>
    const track = document.getElementById('carouselTrack');
    const dots = Array.from(document.querySelectorAll('.dot'));
    const total = dots.length;
    let current = 0;

    function goTo(index: number) {
      current = (index + total) % total;
      if (track) track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
    }

    document
      .getElementById('prevBtn')
      ?.addEventListener('click', () => goTo(current - 1));
    document
      .getElementById('nextBtn')
      ?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    let autoplay = setInterval(() => goTo(current + 1), 6000);
    const carousel = document.getElementById('carousel');
    carousel?.addEventListener('mouseenter', () => clearInterval(autoplay));
    carousel?.addEventListener('mouseleave', () => {
      autoplay = setInterval(() => goTo(current + 1), 6000);
    });

    goTo(0);
  </script>

  <!-- — MARQUEE — -->
  <div class="marquee-wrap">
    <div class="marquee-inner">
      <span class="marquee-item">React</span><span class="marquee-dot">·</span>
      <span class="marquee-item">Next.js</span><span class="marquee-dot">·</span
      >
      <span class="marquee-item">TypeScript</span><span class="marquee-dot"
        >·</span
      >
      <span class="marquee-item">Astro</span><span class="marquee-dot">·</span>
      <span class="marquee-item">Design-first Engineering</span><span
        class="marquee-dot">·</span
      >
      <span class="marquee-item">Front-end Developer</span><span
        class="marquee-dot">·</span
      >
      <span class="marquee-item">React</span><span class="marquee-dot">·</span>
      <span class="marquee-item">Next.js</span><span class="marquee-dot">·</span
      >
      <span class="marquee-item">TypeScript</span><span class="marquee-dot"
        >·</span
      >
      <span class="marquee-item">Astro</span><span class="marquee-dot">·</span>
      <span class="marquee-item">Design-first Engineering</span><span
        class="marquee-dot">·</span
      >
      <span class="marquee-item">Front-end Developer</span><span
        class="marquee-dot">·</span
      >
    </div>
  </div>

  <!-- — CONTACT — -->
  <section class="contact-section" id="contact">
    <div class="fade-up">
      <div class="section-num" style="margin-bottom:12px;">05 / Contact</div>
      <h2 class="contact-heading">
        LET'S<br />BUILD<br /><em>SOMETHING</em><br />GREAT
      </h2>
    </div>
    <div class="fade-up">
      <p class="contact-body">
        Currently available for new partnerships and freelance projects. I'd
        love to hear about what you're building.
      </p>
      <div class="contact-big-email">vkasparevych@gmail.com</div>
      <div class="contact-links" style="margin-bottom:40px;">
        <a
          href="https://github.com/veranikabarel"
          class="contact-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="contact-link-icon">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
              ></path>
            </svg>
          </span>
          GitHub · veranikabarel
        </a>
        <a
          href="https://www.linkedin.com/in/veranika-kasparevych/"
          class="contact-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="contact-link-icon">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </span>
          LinkedIn · Veranika Kasparevych
        </a>
      </div>
      <a href="mailto:vkasparevych@gmail.com" class="btn-primary"
        >Get in touch →</a
      >
    </div>
  </section>
</BaseLayout>
