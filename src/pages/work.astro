---

<style>
  .heroSection {
    padding: 0;
  }
  .hero {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
  }

  .hero p {
    color: var(--color-text-muted);
  }

  .workSection {
    padding: 0;
  }

  .projectGrid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--element-gap-large);
  }

  .projectCard {
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: var(--element-gap-large);
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
    min-height: 280px;
    background: transparent;
  }

  .projectThumb {
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    background: var(--color-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .projectMeta {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--element-gap);
  }

  @media screen and (width >= 768px) {
    .hero {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }

    .projectGrid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<MainLayout title="Work" description="Case studies and websites.">
  <section class="heroSection">
    <div class="hero">
      <div>
        <h1>Work</h1>
        <p>
          Showcase websites, ecommerce builds, and digital experiences. Case
          studies and live links are in progress and will be published here
          soon.
        </p>
      </div>
    </div>
  </section>

