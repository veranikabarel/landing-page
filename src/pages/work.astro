---
import CustomLink from "@components/CustomLink.astro";
import MainLayout from "@layouts/MainLayout.astro";
import Contact from "@sections/Contact.astro";
import Referrals from "@sections/Referrals.astro";
import projectsData from "@data/projects.json";

const placeholderProjects = projectsData.projects ?? [];
---

<style>
  section {
    margin-bottom: var(--section-margin-bottom);
  }

  .heroSection {
    padding: 0;
  }
  .hero {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
  }

  .hero p {
    color: var(--color-text-muted);
  }

  .projectGrid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--element-gap-large);
  }

  .projectCard {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--element-gap-large);
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
    min-height: 280px;
    background: transparent;
  }

  .projectThumb {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    overflow: hidden;
  }

  .projectThumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
  }

  .projectMeta {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--element-gap);
  }

  @media screen and (width >= 768px) {
    .hero {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }

    .projectGrid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<MainLayout title="Work" description="Case studies and websites.">
  <section class="heroSection">
    <div class="hero">
      <div>
        <h3>Work</h3>
        <!-- <p>
          Showcase websites, ecommerce builds, and digital experiences. Case
          studies and live links are in progress and will be published here
          soon.
        </p> -->
      </div>
    </div>

    <div class="projectGrid">
      {
        placeholderProjects.map((project) => (
          <article class="projectCard">
            <div class="projectThumb">
              {project.thumbnail ? (
                <img
                  src={project.thumbnail}
                  alt={`${project.title} thumbnail`}
                  loading="lazy"
                />
              ) : (
                <span>Preview coming soon</span>
              )}
            </div>
            <div>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
            </div>
            <div class="projectMeta">
              <CustomLink href={project.link} text="Check it out" />
            </div>
          </article>
        ))
      }
    </div>
  </section>
  <Referrals />
  <Contact />
</MainLayout>
