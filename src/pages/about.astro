---

<style>
  section {
    margin-bottom: var(--section-margin-bottom);
  }

  .heroSection {
    padding: 0;
  }

  .heroSection p {
    color: var(--color-text-muted);
  }

  .about {
    display: flex;
    flex-direction: column;
  }

  .workSection {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
  }

  .experienceSection {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap-large);
  }

  .experienceCard {
    padding-bottom: var(--element-gap-large);
  }

  .experienceCard:not(:last-child) {
    border-bottom: none;
  }

  .experienceHeader {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--element-gap);
    flex-wrap: wrap;
    margin-bottom: var(--element-gap);
  }

  .experienceMeta {
    display: flex;
    align-items: center;
    gap: var(--element-gap);
  }

  .experienceLogo {
    width: 30%;
    height: 48px;
    /* border-radius: 12px; */
    object-fit: scale-down;
    box-shadow: none;
  }

  .experienceDate {
    color: var(--color-muted);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .responsibilityList {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
    padding-left: 20px;
    list-style: disc;
  }

  .responsibilityList li {
    color: var(--color-muted);
    line-height: 1.5;
  }

  .sectionHeader {
    margin-bottom: var(--heading-margin-bottom);
  }

  .aboutSection {
    padding: 0;
  }

  .attendingSection {
    padding: 0;
  }

  .conferencesSection {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
  }

  .conferencesList {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .conferenceCard {
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--element-gap-large);
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
    transition: transform var(--transition-base);
  }

  .conferenceCard:hover {
    transform: translateY(-2px);
  }

  .conferenceHeader {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
  }

  .conferenceCard h4 {
    margin: 0;
    color: var(--color-text);
    font-size: 1.25rem;
  }

  .conferenceCard h4 a {
    text-decoration: none;
  }

  .conferenceType {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.9rem;
    border-radius: 0;
    background: transparent;
    color: var(--color-accent-strong);
    font-size: 0.85rem;
    font-weight: 600;
    width: fit-content;
  }

  .conferenceDescription {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .languagesSection {
    position: relative;
    padding-inline: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-top: var(--element-gap);
  }

  .languagesSection::before {
    content: "";
    position: absolute;
    inset: 0;
    background: transparent;
    z-index: 0;
  }

  .languagesSection > * {
    position: relative;
    z-index: 1;
  }

  .skillsGrid {
    margin-top: var(--element-gap-large);
    display: grid;
    gap: var(--element-gap);
  }

  .skillCard {
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--element-gap-large);
    display: flex;
    flex-direction: column;
    gap: var(--element-gap-large);
    box-shadow: none;
    backdrop-filter: none;
  }

  .skillCardHeader {
    display: flex;
    gap: var(--element-gap);
    align-items: flex-start;
  }

  .skillIcon {
    width: 52px;
    height: 52px;
    border-radius: 16px;
    background: var(--color-accent);
    display: grid;
    place-items: center;
    color: var(--color-text-primary);
    flex-shrink: 0;
  }

  .skillCard h4 {
    margin-bottom: var(--space-1);
  }

  .skillList {
    list-style: none;
    display: grid;
    gap: var(--element-gap);
    padding: 0;
    margin: 0;
  }

  .skillList li {
    display: flex;
    align-items: center;
    gap: var(--element-gap);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .skillList li::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-highlight);
    display: inline-flex;
    box-shadow: none;
  }
  @media screen and (width >= 768px) {
    .hero {
      flex-direction: row;
      justify-content: space-between;
    }

    .workImagesWrapper {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--element-gap-large);
    }

    .experienceLayout {
      grid-template-columns: 1fr 1fr;
      gap: var(--element-gap-large);
    }

    .experienceHeader {
      flex-direction: row;
    }

    .experienceCompanyData {
      width: -webkit-fill-available;
    }

    .conferencesList {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--element-gap-large);
    }

    .skillsGrid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (width >= 1200px) {
    .aboutImgAndText {
      grid-template-columns: 2fr 1fr;
    }
  }
</style>

<MainLayout title="About me" description=" Lorem ipsum dolor sit amet">
  <!-- <h1 class="heroSection">About</h1> -->
  <!-- <p>
      Highlighting my expertise in UI development, professional experience, technical skills, creative activities, and industry certifications.
    </p> -->

  <section class="experienceSection">
    <div class="sectionHeader">
      <h3>Experience</h3>
    </div>

    {
      experience.experience.map((exp) => (
        <article class="experienceCard">
          <div class="experienceHeader">
            <div class="experienceMeta">
              {exp.logo && (
                <img
                  class="experienceLogo"
                  src={exp.logo}
                  alt={`${exp.company} logo`}
                  loading="lazy"
                  decoding="async"
                />
              )}
              <div class="experienceCompanyData">
                <h5>{exp.job_title}</h5>
                <p>{exp.company}</p>
              </div>
            </div>
            <p class="experienceDate">{exp.date}</p>
          </div>

          {exp.responsibilities?.length > 0 && (
            <ul class="responsibilityList">
              {exp.responsibilities.map((resp: string) => (
                <li>{resp}</li>
              ))}
            </ul>
          )}
        </article>
      ))
    }
  </section>

  <!-- <section class="attendingSection languagesSection">
    <div class="sectionHeader">
      <h3>Skills</h3>
      
    </div>
    <div class="skillsGrid">
      {
        skillSections.map(({ title, icon, items }) => (
          <article class="skillCard">
            <div class="skillCardHeader">
              <span class="skillIcon" set:html={icon} />
              <div>
                <h4>{title}</h4>
              </div>
            </div>
            <ul class="skillList">
              {items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section> -->

  <section class="attendingSection conferencesSection">
    <div>
      <h3>Conferences | Activities</h3>
    </div>
    <ul class="conferencesList">
      {
        activities.presentations.map((presentation) => (
          <li>
            <article class="conferenceCard">
              <div class="conferenceHeader">
                <h4>
                  <a href={presentation.link}>{presentation.title}</a>
                </h4>
                <span class="conferenceType">{presentation.type}</span>
              </div>
              {presentation.description && (
                <p class="conferenceDescription">{presentation.description}</p>
              )}
            </article>
          </li>
        ))
      }
    </ul>
  </section>

  <Contact />
</MainLayout>
