<MainLayout title="About me" description=" Lorem ipsum dolor sit amet">
  <!-- <h1 class="heroSection">About</h1> -->
  <!-- <p>
      Highlighting my expertise in UI development, professional experience, technical skills, creative activities, and industry certifications.
    </p> -->

  <section class="experienceSection">
    <div class="sectionHeader">
      <h3>Experience</h3>
    </div>

    {
      experience.experience.map((exp) => (
        <article class="experienceCard">
          <div class="experienceHeader">
            <div class="experienceMeta">
              {companyLogos[exp.company] && (
                <span
                  class="experienceLogo"
                  set:html={companyLogos[exp.company]}
                />
              )}
              <div class="experienceCompanyData">
                <h5>{exp.job_title}</h5>
                <p>{exp.company}</p>
              </div>
            </div>
            <p class="experienceDate">{exp.date}</p>
          </div>

          {exp.responsibilities?.length > 0 && (
            <ul class="responsibilityList">
              {exp.responsibilities.map((resp: string) => (
                <li>{resp}</li>
              ))}
            </ul>
          )}
        </article>
      ))
    }
  </section>

  <section class="attendingSection languagesSection">
    <div class="sectionHeader">
      <h3>Skills</h3>
    </div>
    <div class="skillsGrid">
      {
        skillSections.map(({ title, icon, items }) => (
          <article class="skillCard">
            <div class="skillCardHeader">
              <span class="skillIcon" set:html={icon} />
              <div>
                <h4>{title}</h4>
              </div>
            </div>
            <ul class="skillList">
              {items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="educationSection">
    <div class="sectionHeader">
      <h3>Education</h3>
    </div>
    {
      education.education.map((edu) => (
        <article class="educationCard">
          <div class="educationMeta">
            <h5>{edu.degree}</h5>
            <p>{edu.institution}</p>
            <p>
              {edu.dates} · {edu.location}
            </p>
          </div>
        </article>
      ))
    }
  </section>

  <section class="certificatesSection">
    <div class="sectionHeader">
      <h3>Certificates</h3>
    </div>
    {
      certificates.certificates.map((cert) => (
        <article class="certificateCard">
          <div class="certificateMeta">
            <h5>{cert.name}</h5>
            <p>
              {cert.issuer} · {cert.date}
            </p>
          </div>
        </article>
      ))
    }
  </section>

  <section class="attendingSection conferencesSection">
    <div>
      <h3>Conferences | Activities</h3>
    </div>
    <ul class="conferencesList">
      {
        activities.presentations.map((presentation) => (
          <li>
            <article class="conferenceCard">
              <div class="conferenceHeader">
                <h4>
                  <a href={presentation.link}>{presentation.title}</a>
                </h4>
                <span class="conferenceType">{presentation.type}</span>
              </div>
              {presentation.description && (
                <p class="conferenceDescription">{presentation.description}</p>
              )}
            </article>
          </li>
        ))
      }
    </ul>
  </section>

  <Referrals />

  <Contact />
</MainLayout>
