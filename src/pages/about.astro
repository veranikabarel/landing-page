    border-radius: var(--radius-md);
    overflow: hidden;
    margin-top: var(--space-4);
  }

  .languagesSection::before {
    content: "";
    position: absolute;
    inset: 0;
    background: transparent;
    z-index: 0;
  }

  .languagesSection > * {
