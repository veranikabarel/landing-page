---

<style>
  section {
    margin-bottom: var(--section-margin-bottom);
  }

  .heroSection {
    padding: 0;
  }

  .heroSection p {
    color: var(--color-text-muted);
  }

  .about {
    display: flex;
    flex-direction: column;
  }

  .workSection {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
  }

  .experienceSection {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap-large);
  }

  .experienceCard {
    padding-bottom: var(--element-gap-large);
  }

  .experienceCard:not(:last-child) {
    border-bottom: none;
  }

  .experienceHeader {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--element-gap);
    flex-wrap: wrap;
    margin-bottom: var(--element-gap);
  }

  .experienceMeta {
    display: flex;
    align-items: center;
    gap: var(--element-gap);
  }

  .experienceLogo {
    width: 30%;
    height: 48px;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .experienceLogo :global(svg) {
    width: 100%;
    height: 48px;
    object-fit: contain;
  }

  .educationSection,
  .certificatesSection {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--element-gap-large);
  }

  .educationSection .sectionHeader,
  .certificatesSection .sectionHeader {
    grid-column: 1 / -1;
  }

  .educationCard,
  .certificateCard {
    padding: var(--element-gap);
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .educationMeta,
  .certificateMeta {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .educationMeta h5,
  .certificateMeta h5 {
    margin: 0;
  }

  .educationMeta p,
  .certificateMeta p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .experienceDate {
    color: var(--color-muted);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .responsibilityList {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
    padding-left: 20px;
    list-style: disc;
  }

  .responsibilityList li {
    color: var(--color-muted);
    line-height: 1.5;
  }

  .sectionHeader {
    margin-bottom: var(--heading-margin-bottom);
  }

  .aboutSection {
    padding: 0;
  }

  .attendingSection {
    padding: 0;
  }

  .conferencesSection {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
  }

  .conferencesList {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .conferenceCard {
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--element-gap-large);
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
    transition: transform var(--transition-base);
  }

  .conferenceCard:hover {
    transform: translateY(-2px);
  }

  .conferenceHeader {
    display: flex;
    flex-direction: column;
    gap: var(--element-gap);
  }

  .conferenceCard h4 {
    margin: 0;
    color: var(--color-text);
    font-size: 1.25rem;
  }

  .conferenceCard h4 a {
    text-decoration: none;
  }

  .conferenceType {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.9rem;
    border-radius: 0;
    background: transparent;
    color: var(--color-accent-strong);
    font-size: 0.85rem;
    font-weight: 600;
    width: fit-content;
  }

  .conferenceDescription {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .languagesSection {
