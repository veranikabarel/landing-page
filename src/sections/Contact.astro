---
import ContactLink from '../components/ContactLink.astro';
---

<section class="contact-section" id="contact">
  <div class="fade-up">
    <div class="section-num section-num--spaced">05 / Contact</div>
    <h2 class="contact-heading">
      LET'S<br />BUILD<br /><em>SOMETHING</em><br />GREAT
    </h2>
  </div>
  <div class="fade-up">
    <p class="contact-body">
      Currently available for new partnerships and freelance projects. I'd
      love to hear about what you're building.
    </p>
    <div class="contact-big-email">vkasparevych@gmail.com</div>
    <div class="contact-links">
      <ContactLink href="https://github.com/veranikabarel" label="GitHub · veranikabarel">
        <svg
          slot="icon"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
          ></path>
        </svg>
      </ContactLink>
      <ContactLink
        href="https://www.linkedin.com/in/veranika-kasparevych/"
        label="LinkedIn · Veranika Kasparevych"
      >
        <svg
          slot="icon"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path>
          <rect x="2" y="9" width="4" height="12"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
      </ContactLink>
    </div>
    <a href="mailto:vkasparevych@gmail.com" class="btn-primary">Get in touch →</a>
  </div>
</section>
