---
import CustomButton from "@components/CustomButton.astro";
import HeaderLink from "./HeaderLink.astro";
---

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
  }

  .topnav {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0.75rem;
    margin-bottom: var(--section-margin-bottom);
  }

  .internal-links {
    position: absolute;
    top: calc(100% + 1rem);

    display: flex;
    flex-direction: column;
    gap: 2rem;

    padding: 1.25rem;
    background: var(--color-bg-card);
    border-radius: 14px;
    backdrop-filter: blur(18px);

    width: 100vw;
    left: 0;
    right: 0;

    transform: translateY(-8px) scale(0.98);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;

    transition:
      transform 280ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 200ms ease,
      visibility 0ms linear 280ms;
  }

  .internal-links.show {
    transform: translateY(0) scale(1);
    opacity: 1;
    visibility: visible;
    pointer-events: auto;

    transition:
      transform 280ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 200ms ease,
      visibility 0ms;
  }

  .nav-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-actions {
    display: flex;
    align-items: center;
  }

  .menu-toggle {
    width: 28px;
    height: 22px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    cursor: pointer;
  }

  .menu-toggle span {
    height: 2px;
    width: 100%;
    background: var(--color-text);
    border-radius: 2px;
    transition:
      transform 250ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 200ms ease;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: translateY(10px) rotate(45deg);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: translateY(-10px) rotate(-45deg);
  }

  .nav-list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .nav-list a {
    padding: 0.35rem 0.25rem;
    font-weight: 500;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .topnav {
      padding: 0 1.75rem;
    }

    .nav-actions {
      display: none;
    }

    .internal-links {
      position: static;

      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;

      padding: 0;
      background: transparent;
      filter: none;
      backdrop-filter: none;

      width: 100%;
      min-width: unset;

      transform: none;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition: none;
    }
    .nav-list {
      flex-direction: row;
      gap: 1.25rem;
    }

    .menu-toggle {
      display: none;
    }

    .button-wrapper {
      display: flex;
    }
  }

  @media (width >= 1200px) {
    .topnav {
      padding: 0;
      margin-bottom: 0;
    }
  }
</style>

<header class="site-header" aria-label="Primary">
  <nav class="topnav">
    <div class="internal-links" id="primary-navigation">
      <ul class="nav-list" role="menubar">
        <li role="none">
          <HeaderLink href="/">Home</HeaderLink>
        </li>
        <li role="none">
          <HeaderLink href="/about">About</HeaderLink>
        </li>
        <!-- <li role="none">
          <HeaderLink href="/work">Work</HeaderLink>
        </li>
        <li role="none">
          <HeaderLink href="/blog">Blog</HeaderLink>
        </li>
        <li role="none">
          <HeaderLink href="/contact">Contact</HeaderLink>
        </li> -->
      </ul>
    </div>

    <div class="button-wrapper">
      <CustomButton
        href="/cv-veranika-kasparevych.pdf"
        download="cv-veranika-kasparevych.pdf"
        text="Download CV"
        aria-label="Download Veranika Kasparevych CV"
      />
    </div>

    <div class="nav-actions">
      <div
        class="menu-toggle"
        id="menuToggle"
        aria-label="Toggle navigation"
        aria-controls="primary-navigation"
        aria-expanded="false"
      >
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>
  </nav>
</header>

<script is:inline>
  const toggle = document.getElementById("menuToggle");
  const navLinks = document.getElementById("primary-navigation");

  const toggleMenu = () => {
    const isOpen = navLinks.classList.toggle("show");
    toggle.classList.toggle("active", isOpen);
    toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
  };

  toggle?.addEventListener("click", toggleMenu);

  navLinks.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      navLinks.classList.remove("show");
      toggle.classList.remove("active");
      toggle.setAttribute("aria-expanded", "false");
    });
  });
</script>
