---
import CustomButton from "@components/CustomButton.astro";
import HeaderLink from "./HeaderLink.astro";
---

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
  }

  .topnav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: 0;
    border: none;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
  }

  /* .branding {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: inherit;
    font-weight: 600;
  } */

  /* .brand-mark {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-strong));
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    letter-spacing: 0.04em;
    box-shadow: 0 12px 20px rgba(124, 77, 255, 0.35);
  } */

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-text-muted);
  }

  .menu-toggle {
    /* width: 48px;
    height: 48px; */
    color: var(--color-text);
  }

  .menu-toggle svg {
    width: 24px;
    height: 24px;
  }

  .internal-links {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 1rem;
    display: none;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background: rgba(10, 10, 10, 0.95);
    border-radius: 0;
    border: none;
    box-shadow: none;
    min-width: min(280px, 90vw);
    backdrop-filter: blur(18px);
  }

  .internal-links.show {
    display: flex;
  }

  .nav-list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .nav-list a {
    padding: 0.35rem 0.25rem;
    font-weight: 500;
  }

  .button-wrapper {
    display: none;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .topnav {
      padding: 1rem 2rem;
      justify-content: space-between;
    }

    .nav-actions {
      display: none;
    }

    .internal-links {
      position: static;
      display: flex !important;
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
      padding: 0;
      background: transparent;
      border: none;
      box-shadow: none;
      min-width: unset;
    }

    .nav-list {
      flex-direction: row;
      align-items: center;
      gap: 1.25rem;
    }

    .menu-toggle {
      display: none;
    }

    .button-wrapper {
      display: block;
    }
  }
</style>

<header class="site-header" aria-label="Primary">
  <nav class="topnav">
    <!-- <a class="branding" href="/">
      <span class="brand-mark">VK</span>
    </a> -->

    <div class="internal-links" id="primary-navigation">
      <ul class="nav-list" role="menubar">
        <li role="none">
          <HeaderLink href="/">Home</HeaderLink>
        </li>
        <li role="none">
          <HeaderLink href="/about">About</HeaderLink>
        </li>
        <li role="none">
          <HeaderLink href="/work">Work</HeaderLink>
        </li>
        <li role="none">
          <HeaderLink href="/contact">Contact</HeaderLink>
        </li>
      </ul>
    </div>

    <div class="button-wrapper">
      <CustomButton
        href="/cv-template.md"
        download="Veranika-Kasperevych-CV-Template.md"
        text="Download CV"
        aria-label="Download Veranika Kasparevych CV template"
      />
    </div>

    <div class="nav-actions">
      <div
        class="menu-toggle"
        id="menuToggle"
        aria-label="Toggle navigation"
        aria-controls="primary-navigation"
        aria-expanded="false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path fill="currentColor" d="M3 6h18v2H3zm0 5h18v2H3zm0 5h18v2H3z"
          ></path>
        </svg>
      </div>
    </div>
  </nav>
</header>

<script is:inline>
  const toggle = document.getElementById("menuToggle");
  const navLinks = document.getElementById("primary-navigation");

  const closeMenu = () => {
    navLinks.classList.remove("show");
    toggle?.setAttribute("aria-expanded", "false");
  };

  const openMenu = () => {
    navLinks.classList.add("show");
    toggle?.setAttribute("aria-expanded", "true");
  };

  toggle?.addEventListener("click", () => {
    const isExpanded = toggle.getAttribute("aria-expanded") === "true";
    if (isExpanded) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  const links = navLinks.querySelectorAll("a");
  links.forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768) {
      navLinks.classList.add("show");
    } else {
      closeMenu();
    }
  });
</script>
