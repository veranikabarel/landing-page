---
const { href, text, variant = "primary", ...props } = Astro.props;
---

<style>
  .cta-link {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: 14px;
    padding: 12px 20px;
    background: linear-gradient(135deg, #FFB6D9, #DDA0DD);
    color: white;
    font-weight: 600;
    box-shadow: none;
    transition:
      transform 220ms ease,
      filter var(--transition-base);
  }

  .cta-link:hover {
    transform: translateY(-2px);
    box-shadow: none;
    filter: brightness(1.05);
  }

  .cta-link:active {
    transform: translateY(0);
  }

  .cta-link.outline {
    background: transparent;
    color: var(--color-text);
    border: none;
    box-shadow: none;
    border-radius: 0;
    padding: 0;
    text-decoration: underline;
    text-decoration-color: rgba(255, 182, 217, 0.4);
    text-underline-offset: 3px;
    font-weight: 500;
    transition:
      color 300ms cubic-bezier(0.4, 0, 0.2, 1),
      text-decoration-color 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .cta-link.outline:hover {
    color: var(--color-electric-blue);
    box-shadow: none;
    background: transparent;
    transform: none;
    text-decoration-color: currentColor;
  }
</style>

<a
  href={href}
  class:list={["cta-link", { outline: variant === "outline" }]}
  {...props}
>
  {text}
</a>
