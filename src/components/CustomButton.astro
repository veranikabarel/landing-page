---
const { onclick, text, ...props } = Astro.props;
---

<style>
  .button {
    background-color: var(--gray);
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .button {
    text-decoration: none;
    color: var(--black);
    font-family: inherit;
    padding: 12px 24px;
    transition:
      background-color 0.3s,
      color 0.3s;
  }

  .button:hover {
    background-color: var(--yellow);
    color: var(--black);
  }

  .button:focus {
    outline: none;
  }

  .button:active {
    background-color: var(--yellow);
    color: var(--white);
  }

  .button:visited {
    color: var(--black);
  }
</style>

<button onclick={onclick} class="button">{text}</button>
