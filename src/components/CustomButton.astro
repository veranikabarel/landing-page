---
const {
  onclick,
  text,
  type = "button",
  variant = "primary",
  href,
  download,
  target,
  rel,
  ...props
} = Astro.props;
---

<style>
  .cta {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--button-padding);
    font-weight: 600;
    background: var(--color-accent);
    color: var(--color-text-primary);
    cursor: pointer;
    font-family: inherit;
    box-shadow: none;
    width: max-content;
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-base),
      filter var(--transition-base);
  }

  .cta:hover {
    transform: translateY(var(--translate-lift-sm));
    box-shadow: var(--gradient-glow);
    filter: brightness(1.02);
  }

  .cta:active {
    transform: translateY(0);
  }

  .cta.outline {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
    box-shadow: none;
  }

  .cta.outline:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    box-shadow: none;
    background: transparent;
  }
</style>

{
  href ? (
    <a
      href={href}
      download={download}
      target={target}
      rel={target === "_blank" ? (rel ?? "noopener noreferrer") : rel}
      class:list={["cta", { outline: variant === "outline" }]}
      {...props}
    >
      {text}
    </a>
  ) : (
    <button
      type={type}
      onclick={onclick}
      class:list={["cta", { outline: variant === "outline" }]}
      {...props}
    >
      {text}
    </button>
  )
}
