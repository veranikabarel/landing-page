---
const {
  onclick,
  text,
  type = "button",
  variant = "primary",
  href,
  download,
  target,
  rel,
  ...props
} = Astro.props;
---

<style>
  .cta {
    border: none;
    border-radius: 14px;
    padding: 12px 20px;
    font-weight: 600;
    background: linear-gradient(135deg, #FFB6D9, #DDA0DD);
    color: white;
    cursor: pointer;
    font-family: inherit;
    box-shadow: none;
    transition:
      transform 220ms ease,
      filter var(--transition-base);
  }

  .cta:hover {
    transform: translateY(-2px);
    box-shadow: none;
    filter: brightness(1.05);
  }

  .cta:active {
    transform: translateY(0);
  }

  .cta.outline {
    background: transparent;
    color: var(--color-text);
    border: none;
    box-shadow: none;
  }

  .cta.outline:hover {
    color: var(--color-electric-blue);
    box-shadow: none;
    background: var(--color-sky-blue-tint);
  }
</style>

{
  href ? (
    <a
      href={href}
      download={download}
      target={target}
      rel={target === "_blank" ? (rel ?? "noopener noreferrer") : rel}
      class:list={["cta", { outline: variant === "outline" }]}
      {...props}
    >
      {text}
    </a>
  ) : (
    <button
      type={type}
      onclick={onclick}
      class:list={["cta", { outline: variant === "outline" }]}
      {...props}
    >
      {text}
    </button>
  )
}
